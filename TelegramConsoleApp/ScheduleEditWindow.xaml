<Window x:Class="TelegramConsoleApp.ScheduleEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑定时任务" Width="620" Height="560" MinWidth="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F7FA" FontFamily="Microsoft YaHei UI" FontSize="13">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="52" />
        </Grid.RowDefinitions>
        <GroupBox Header="任务配置" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="125" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="70" />
                </Grid.RowDefinitions>

                <TextBlock Text="任务状态" VerticalAlignment="Center" />
                <CheckBox x:Name="EnabledBox" Grid.Column="1" Content="启用此任务" VerticalAlignment="Center" />

                <TextBlock Grid.Row="1" Text="目标群聊" VerticalAlignment="Center" />
                <ComboBox x:Name="TargetBox" Grid.Row="1" Grid.Column="1" DisplayMemberPath="Name" />

                <TextBlock Grid.Row="2" Text="执行周期" VerticalAlignment="Center" />
                <ComboBox x:Name="PeriodBox" Grid.Row="2" Grid.Column="1" SelectionChanged="PeriodBox_SelectionChanged">
                    <ComboBoxItem Content="每天" Tag="Daily" />
                    <ComboBoxItem Content="每周" Tag="Weekly" />
                </ComboBox>

                <TextBlock Grid.Row="3" Text="每周执行日" VerticalAlignment="Center" />
                <UniformGrid x:Name="WeekDaysPanel" Grid.Row="3" Grid.Column="1" Rows="1">
                    <CheckBox x:Name="MondayBox" Content="周一" VerticalAlignment="Center" />
                    <CheckBox x:Name="TuesdayBox" Content="周二" VerticalAlignment="Center" />
                    <CheckBox x:Name="WednesdayBox" Content="周三" VerticalAlignment="Center" />
                    <CheckBox x:Name="ThursdayBox" Content="周四" VerticalAlignment="Center" />
                    <CheckBox x:Name="FridayBox" Content="周五" VerticalAlignment="Center" />
                    <CheckBox x:Name="SaturdayBox" Content="周六" VerticalAlignment="Center" />
                    <CheckBox x:Name="SundayBox" Content="周日" VerticalAlignment="Center" />
                </UniformGrid>

                <TextBlock Grid.Row="4" Text="执行时间" VerticalAlignment="Center" />
                <TextBox x:Name="TimeBox" Grid.Row="4" Grid.Column="1" ToolTip="格式 HH:mm，例如 08:00" />

                <TextBlock Grid.Row="5" Text="发送内容" VerticalAlignment="Center" />
                <TextBox x:Name="MessageBox" Grid.Row="5" Grid.Column="1" />

                <TextBlock Grid.Row="6" Text="Telegram 完成确认" VerticalAlignment="Center" />
                <ComboBox x:Name="ConfirmationPeerBox" Grid.Row="6" Grid.Column="1" DisplayMemberPath="Name" />

                <TextBlock Grid.Row="7" Text="确认邮件" VerticalAlignment="Center" />
                <TextBox x:Name="ConfirmationEmailBox" Grid.Row="7" Grid.Column="1" ToolTip="不发送邮件时留空" />

                <TextBlock Grid.Row="8" Text="确认内容" VerticalAlignment="Top" Margin="0,9,0,0" />
                <TextBox x:Name="ConfirmationTextBox" Grid.Row="8" Grid.Column="1"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"
                         ToolTip="支持 {群聊}、{时间}、{内容}" />
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="取消" Width="95" IsCancel="True" />
            <Button Content="保存修改" Width="110" IsDefault="True" Click="SaveButton_Click"
                    Background="#2481CC" Foreground="White" />
        </StackPanel>
    </Grid>
</Window>
