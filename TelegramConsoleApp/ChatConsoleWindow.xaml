<Window x:Class="TelegramConsoleApp.ChatConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:TelegramConsoleApp"
        Icon="Assets/AppIcon.ico"
        Width="820" Height="560" MinWidth="540" MinHeight="340"
        WindowStartupLocation="CenterScreen" Background="#000000"
        FontFamily="Cascadia Mono, Consolas" FontSize="14"
        WindowStyle="None" ResizeMode="CanResize"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="TitleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E5E5E5" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A3A3A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#505050" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#C42B1C" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#A32318" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" CornerRadius="8" GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>
    <Grid Background="#000000">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="1" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="48" />
            <RowDefinition Height="27" />
        </Grid.RowDefinitions>

        <Border Background="#202020" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="8,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Border Height="34" MinWidth="280" MaxWidth="450" Background="#0C0C0C"
                            CornerRadius="7,7,0,0" Padding="10,0,4,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="30" />
                            </Grid.ColumnDefinitions>
                            <Border Width="16" Height="14" BorderBrush="#D4D4D4" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="›_" Foreground="#D4D4D4" FontSize="8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="PeerTitle" Foreground="#FFFFFF" FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="AccountTitle" Foreground="#60A5FA" FontSize="10"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Button Grid.Column="2" Content="×" Style="{StaticResource TitleButtonStyle}"
                                    Width="30" Height="30" FontSize="17" Click="CloseButton_Click" />
                        </Grid>
                    </Border>
                    <Button Content="＋" Style="{StaticResource TitleButtonStyle}" Width="42" Height="38"
                            FontSize="20" ToolTip="当前仅打开一个会话标签" />
                    <Button Content="⌄" Style="{StaticResource TitleButtonStyle}" Width="34" Height="38"
                            FontSize="16" ToolTip="标签菜单" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="—" Style="{StaticResource TitleButtonStyle}" Click="MinimizeButton_Click" />
                    <Button x:Name="MaximizeButton" Content="□" Style="{StaticResource TitleButtonStyle}"
                            Click="MaximizeButton_Click" />
                    <Button Content="×" Style="{StaticResource CloseButtonStyle}" FontSize="18"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <local:BufferedTerminal x:Name="ConsoleBox" Grid.Row="1"
                                Background="#000000" Foreground="#FFFFFF" BorderThickness="0"
                                MaximumLines="1000" MaximumCharacters="500000"
                                PreviewMouseLeftButtonUp="ConsoleBox_PreviewMouseLeftButtonUp"
                                PreviewMouseRightButtonDown="ConsoleBox_PreviewMouseRightButtonDown"
                                ContextMenuOpening="ConsoleBox_ContextMenuOpening">
            <local:BufferedTerminal.ContextMenu>
                <ContextMenu Background="#18181B" Foreground="#FFFFFF">
                    <MenuItem x:Name="ConsoleQuoteMenuItem" Header="{DynamicResource QuoteReply}"
                              Click="ConsoleQuoteMenuItem_Click" />
                </ContextMenu>
            </local:BufferedTerminal.ContextMenu>
        </local:BufferedTerminal>

        <Border Grid.Row="2" Background="#3F3F46" />

        <Border x:Name="QuotePreviewPanel" Grid.Row="3" Visibility="Collapsed"
                Background="#111827" BorderBrush="#3B82F6" BorderThickness="3,0,0,0"
                Padding="10,4" Margin="12,4,12,0">
            <Grid>
                <TextBlock x:Name="QuotePreviewText" Foreground="#BFDBFE" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" Margin="0,0,34,0" />
                <Button Content="×" HorizontalAlignment="Right" Width="28" Padding="0"
                        Background="#18181B" Foreground="#FFFFFF" BorderBrush="#3F3F46"
                        ToolTip="{DynamicResource ClearQuote}" Click="ClearQuoteButton_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="12,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="26" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="74" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="›" Foreground="#22C55E" FontSize="22"
                       VerticalAlignment="Center" FontWeight="Bold" />
            <TextBox x:Name="InputBox" Grid.Column="1" Padding="2" Background="#000000"
                     Foreground="#FFFFFF" BorderThickness="0" CaretBrush="#FFFFFF"
                     VerticalContentAlignment="Center" KeyDown="InputBox_KeyDown"
                     TextChanged="InputBox_TextChanged" />
            <Button x:Name="SendButton" Grid.Column="2" Content="SEND ↵" Click="SendButton_Click"
                    Background="#18181B" Foreground="#FFFFFF" BorderBrush="#3F3F46"
                    Padding="6,3" IsEnabled="False" />
        </Grid>

        <Border Grid.Row="5" Background="#09090B" Padding="12,0">
            <Grid>
                <TextBlock VerticalAlignment="Center" Foreground="#71717A" FontSize="11"
                           Text="{DynamicResource ConsoleHelp}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="AccountStatusText" Foreground="#FBBF24" FontSize="11" Margin="0,0,14,0" />
                    <TextBlock Text="{DynamicResource SelfLegend}" Foreground="#22C55E" FontSize="11" />
                    <TextBlock Text="{DynamicResource MessageLegend}" Foreground="#FFFFFF" FontSize="11" />
                    <TextBlock Text="{DynamicResource MentionLegend}" Foreground="#3B82F6" FontSize="11" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
