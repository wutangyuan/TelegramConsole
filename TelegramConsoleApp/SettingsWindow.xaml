<Window x:Class="TelegramConsoleApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource SettingsTitle}" Icon="Assets/AppIcon.ico" Width="660" Height="610" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="#F5F7FA"
        FontFamily="Microsoft YaHei UI" FontSize="13">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="220" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource Language}" VerticalAlignment="Center" />
            <ComboBox x:Name="LanguageBox" Grid.Column="1">
                <ComboBoxItem Content="{DynamicResource FollowSystem}" Tag="" />
                <ComboBoxItem Content="{DynamicResource Chinese}" Tag="zh-CN" />
                <ComboBoxItem Content="{DynamicResource English}" Tag="en-US" />
            </ComboBox>
        </Grid>
        <TabControl Grid.Row="1" Margin="0,4,0,0">
          <TabItem Header="{DynamicResource ProxyTab}">
           <GroupBox Header="{DynamicResource ProxySettings}" Padding="12" Margin="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="72" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="{DynamicResource EnableProxy}" VerticalAlignment="Center" />
                <CheckBox x:Name="EnabledBox" Grid.Column="1" Content="{DynamicResource ProxyEnabled}"
                          VerticalAlignment="Center" Checked="ProxyOption_Changed" Unchecked="ProxyOption_Changed" />

                <TextBlock Grid.Row="1" Text="{DynamicResource ProxyType}" VerticalAlignment="Center" />
                <ComboBox x:Name="TypeBox" Grid.Row="1" Grid.Column="1" SelectionChanged="ProxyOption_Changed">
                    <ComboBoxItem Content="SOCKS5" Tag="Socks5" />
                    <ComboBoxItem Content="Telegram MTProxy" Tag="MtProxy" />
                </ComboBox>

                <TextBlock Grid.Row="2" Text="{DynamicResource Address}" VerticalAlignment="Center" />
                <Grid Grid.Row="2" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="HostBox" Text="127.0.0.1" />
                    <TextBox x:Name="PortBox" Grid.Column="1" Text="7890" />
                    <Button x:Name="TestButton" Grid.Column="2" Content="{DynamicResource TestPort}" Click="TestButton_Click" />
                </Grid>

                <TextBlock Grid.Row="3" Text="{DynamicResource UserName}" VerticalAlignment="Center" />
                <TextBox x:Name="UserNameBox" Grid.Row="3" Grid.Column="1" ToolTip="{DynamicResource NoAuthHint}" />

                <TextBlock Grid.Row="4" Text="{DynamicResource Password}" VerticalAlignment="Center" />
                <PasswordBox x:Name="PasswordBox" Grid.Row="4" Grid.Column="1" ToolTip="{DynamicResource NoAuthHint}" />

                <TextBlock Grid.Row="5" Text="{DynamicResource MtProxyLink}" VerticalAlignment="Top" Margin="0,9,0,0" />
                <TextBox x:Name="MtProxyUrlBox" Grid.Row="5" Grid.Column="1" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalContentAlignment="Top"
                         ToolTip="例如 https://t.me/proxy?server=...&amp;port=...&amp;secret=..." />

                <Border Grid.Row="6" Grid.ColumnSpan="2" Background="#E8F1FA" Padding="10" Margin="0,8,0,0">
                    <TextBlock x:Name="HintText" TextWrapping="Wrap"
                               Text="{DynamicResource ProxyHint}" />
                </Border>
            </Grid>
           </GroupBox>
          </TabItem>
          <TabItem Header="{DynamicResource EmailTab}">
            <GroupBox Header="{DynamicResource SmtpSettings}" Padding="14" Margin="8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="125" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="44" /><RowDefinition Height="44" />
                  <RowDefinition Height="44" /><RowDefinition Height="44" />
                  <RowDefinition Height="44" /><RowDefinition Height="44" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="{DynamicResource Server}" VerticalAlignment="Center" />
                <TextBox x:Name="SmtpHostBox" Grid.Column="1" />
                <TextBlock Grid.Row="1" Text="{DynamicResource Port}" VerticalAlignment="Center" />
                <TextBox x:Name="SmtpPortBox" Grid.Row="1" Grid.Column="1" Text="587" />
                <TextBlock Grid.Row="2" Text="{DynamicResource Account}" VerticalAlignment="Center" />
                <TextBox x:Name="SmtpUserBox" Grid.Row="2" Grid.Column="1" />
                <TextBlock Grid.Row="3" Text="{DynamicResource PasswordAuthCode}" VerticalAlignment="Center" />
                <PasswordBox x:Name="SmtpPasswordBox" Grid.Row="3" Grid.Column="1" />
                <TextBlock Grid.Row="4" Text="{DynamicResource FromAddress}" VerticalAlignment="Center" />
                <TextBox x:Name="SmtpFromBox" Grid.Row="4" Grid.Column="1" />
                <TextBlock Grid.Row="5" Text="SSL" VerticalAlignment="Center" />
                <CheckBox x:Name="SmtpSslBox" Grid.Row="5" Grid.Column="1" Content="{DynamicResource EnableSsl}" IsChecked="True" VerticalAlignment="Center" />
                <Border Grid.Row="6" Grid.ColumnSpan="2" Background="#E8F1FA" Padding="12" Margin="0,10,0,0">
                  <TextBlock Text="{DynamicResource EmailConfigHint}" TextWrapping="Wrap" VerticalAlignment="Top" />
                </Border>
              </Grid>
            </GroupBox>
          </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="{DynamicResource Cancel}" Width="90" IsCancel="True" />
            <Button Content="{DynamicResource Save}" Width="100" IsDefault="True" Click="SaveButton_Click"
                    Background="#2481CC" Foreground="White" />
        </StackPanel>
    </Grid>
</Window>
