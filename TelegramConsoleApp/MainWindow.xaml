<Window x:Class="TelegramConsoleApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TelegramConsoleApp"
        Title="{DynamicResource AppTitle}"
        Icon="Assets/AppIcon.ico"
        Width="1280" Height="820" MinWidth="1040" MinHeight="700"
        WindowStartupLocation="CenterScreen" Background="{StaticResource PageBrush}"
        FontFamily="Microsoft YaHei UI" FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="64" />
        </Grid.RowDefinitions>

        <GroupBox Header="{DynamicResource ConnectionSettings}" Padding="10" Margin="0,0,0,10">
            <Grid>
              <Grid x:Name="LoginFormPanel">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="API ID" VerticalAlignment="Center" Margin="4" />
                <TextBox x:Name="ApiIdBox" Grid.Column="1" />
                <TextBlock Grid.Column="2" Text="API Hash" VerticalAlignment="Center" Margin="8,4,4,4" />
                <PasswordBox x:Name="ApiHashBox" Grid.Column="3" />
                <TextBlock Grid.Column="4" Text="{DynamicResource PhoneNumber}" VerticalAlignment="Center" Margin="8,4,4,4" />
                <TextBox x:Name="PhoneBox" Grid.Column="5" />
                <Grid Grid.Column="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="LoginButton" Content="{DynamicResource Login}"
                            Click="LoginButton_Click" Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Grid.Column="1" Content="{DynamicResource Settings}" Click="SettingsButton_Click" />
                </Grid>

                <TextBlock x:Name="LoginPromptLabel" Grid.Row="1" Text="{DynamicResource VerificationCode}"
                           VerticalAlignment="Center" Visibility="Collapsed" Margin="4" />
                <TextBox x:Name="LoginValueBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5"
                         Visibility="Collapsed" KeyDown="LoginValueBox_KeyDown" />
                <PasswordBox x:Name="LoginPasswordBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5"
                             Visibility="Collapsed" KeyDown="LoginPasswordBox_KeyDown" />
                <Button x:Name="ContinueLoginButton" Grid.Row="1" Grid.Column="6" Content="{DynamicResource ContinueLogin}"
                        Visibility="Collapsed" Click="ContinueLoginButton_Click" />
              </Grid>
              <Grid x:Name="LoggedInPanel" Height="42" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="110" />
                </Grid.ColumnDefinitions>
                <Border x:Name="ConnectionStatusDot" Width="12" Height="12" CornerRadius="6" Background="#22C55E"
                        VerticalAlignment="Center" Margin="4,0,10,0" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource LoggedInAccount}" FontWeight="SemiBold" />
                    <TextBlock x:Name="LoggedInAccountText" FontWeight="Bold" Foreground="#166534" />
                    <TextBlock Text="　·　" Foreground="#94A3B8" />
                    <TextBlock x:Name="ConnectionStatusText" Text="{DynamicResource Online}"
                               FontWeight="SemiBold" Foreground="#16A34A" />
                </StackPanel>
                <Button Grid.Column="2" Content="{DynamicResource ProductivityTools}" Click="ProductivityTools_Click" />
                <Button Grid.Column="3" Content="{DynamicResource Settings}" Click="SettingsButton_Click" />
              </Grid>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="DialogColumn" Width="290" MinWidth="0" />
                <ColumnDefinition Width="34" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="70" />
                    </Grid.ColumnDefinitions>
                    <Button Content="{DynamicResource RefreshDialogs}" Click="RefreshDialogs_Click" Margin="0,0,3,0" Padding="7,5" FontSize="12" />
                    <Button Grid.Column="1" Content="{DynamicResource OpenConsole}" Click="OpenConsole_Click" Margin="3,0,0,0" Padding="7,5" FontSize="12" />
                    <Button Grid.Column="2" Content="{DynamicResource BlankScreen}" Click="BlankConsole_Click" Margin="6,0,0,0" Padding="7,5" FontSize="12"
                            ToolTip="取消当前会话并停止在聊天终端显示消息" />
                </Grid>
                <TextBox x:Name="DialogFilterBox" Grid.Row="1" TextChanged="DialogFilterBox_TextChanged"
                         ToolTip="输入名称筛选会话" Margin="0,0,0,6" />
                <ListBox x:Name="DialogsList" Grid.Row="2" SelectionChanged="DialogsList_SelectionChanged"
                         MouseDoubleClick="DialogsList_MouseDoubleClick"
                         DisplayMemberPath="Name" BorderBrush="#CBD5E1">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{DynamicResource OpenInConsole}" Click="OpenConsole_Click" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>
            </Grid>

            <Grid Grid.Column="1">
                <GridSplitter Width="7" HorizontalAlignment="Left" Background="#E2E8F0" />
                <Button x:Name="ToggleDialogsButton" Content="❮" Width="26" Height="64"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Padding="0" Margin="0" ToolTip="收起会话列表"
                        Click="ToggleDialogsButton_Click" />
            </Grid>

            <TabControl Grid.Column="2" Margin="4,0,0,0">
                <TabItem Header="{DynamicResource ChatTerminal}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="48" />
                        </Grid.RowDefinitions>
                        <local:BufferedTerminal x:Name="ChatConsole" FontFamily="Cascadia Mono, Consolas"
                                                FontSize="14" Background="#090D12" Foreground="#F8FAFC"
                                                BorderBrush="#1E293B" BorderThickness="1"
                                                MaximumLines="1000" MaximumCharacters="500000"
                                                ContextMenuOpening="ChatConsole_ContextMenuOpening">
                            <local:BufferedTerminal.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Name="ChatQuoteMenuItem" Header="{DynamicResource QuoteReply}"
                                              Click="ChatQuoteMenuItem_Click" />
                                </ContextMenu>
                            </local:BufferedTerminal.ContextMenu>
                        </local:BufferedTerminal>
                        <Border x:Name="QuotePreviewPanel" Grid.Row="1" Visibility="Collapsed"
                                Background="#EFF6FF" BorderBrush="#60A5FA" BorderThickness="3,0,0,0"
                                Padding="10,4" Margin="0,8,0,0">
                            <Grid>
                                <TextBlock x:Name="QuotePreviewText" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" Foreground="#1E3A8A" />
                                <Button Content="×" HorizontalAlignment="Right" Width="30" Padding="0"
                                        ToolTip="{DynamicResource ClearQuote}" Click="ClearQuoteButton_Click" />
                            </Grid>
                        </Border>
                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="MessageBox" AcceptsReturn="True" KeyDown="MessageBox_KeyDown"
                                     ToolTip="Enter 发送，Shift+Enter 换行" Margin="0,0,8,0" />
                            <Button x:Name="SendButton" Grid.Column="1" Content="{DynamicResource Send}" Click="SendButton_Click"
                                    Style="{StaticResource PrimaryButtonStyle}" Margin="0" />
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource GroupMonitor}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="38" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <CheckBox x:Name="MonitorEnabledBox"
                                  Content="{DynamicResource MonitorEnabled}"
                                  VerticalAlignment="Center" Checked="MonitorEnabledBox_Changed"
                                  Unchecked="MonitorEnabledBox_Changed" />
                        <local:BufferedTerminal x:Name="MonitorConsole" Grid.Row="1"
                                                FontFamily="Cascadia Mono, Consolas" FontSize="14"
                                                Background="#090D12" Foreground="#F8FAFC"
                                                BorderBrush="#1E293B" BorderThickness="1"
                                                MaximumLines="1500" MaximumCharacters="750000" />
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource Schedules}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="32" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="38" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource Chat}" VerticalAlignment="Center" />
                            <ComboBox x:Name="ScheduleChatBox" Grid.Column="1" DisplayMemberPath="Name" />
                            <TextBlock Grid.Column="2" Text="{DynamicResource Time}" VerticalAlignment="Center" Margin="8,0,0,0" />
                            <TextBox x:Name="ScheduleTimeBox" Grid.Column="3" Text="08:00" />
                            <TextBlock Grid.Column="4" Text="{DynamicResource Content}" VerticalAlignment="Center" Margin="8,0,0,0" />
                            <TextBox x:Name="ScheduleMessageBox" Grid.Column="5" Text="今日签到" />
                            <Button Grid.Column="6" Content="{DynamicResource AddTask}" Click="AddSchedule_Click" />
                            <Button x:Name="RunNowButton" Grid.Column="7" Content="{DynamicResource RunNow}" Click="RunNow_Click"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Grid.Column="8" Content="{DynamicResource EditSelected}" Click="EditSchedule_Click" />
                            <Button Grid.Column="9" Content="{DynamicResource DeleteSelected}" Click="RemoveSchedule_Click" />
                            <TextBlock Grid.Row="1" Text="{DynamicResource Period}" VerticalAlignment="Center" />
                            <ComboBox x:Name="SchedulePeriodBox" Grid.Row="1" Grid.Column="1"
                                      SelectionChanged="SchedulePeriodBox_SelectionChanged">
                                <ComboBoxItem Content="{DynamicResource Daily}" Tag="Daily" />
                                <ComboBoxItem Content="{DynamicResource Weekly}" Tag="Weekly" />
                            </ComboBox>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{DynamicResource Weekday}" VerticalAlignment="Center" Margin="8,0,0,0" />
                            <UniformGrid x:Name="ScheduleWeekDaysPanel" Grid.Row="1" Grid.Column="3"
                                         Grid.ColumnSpan="7" Rows="1" IsEnabled="False" Margin="4,0">
                                <CheckBox x:Name="AddMonday" Content="{DynamicResource MondayShort}" VerticalAlignment="Center" />
                                <CheckBox x:Name="AddTuesday" Content="{DynamicResource TuesdayShort}" VerticalAlignment="Center" />
                                <CheckBox x:Name="AddWednesday" Content="{DynamicResource WednesdayShort}" VerticalAlignment="Center" />
                                <CheckBox x:Name="AddThursday" Content="{DynamicResource ThursdayShort}" VerticalAlignment="Center" />
                                <CheckBox x:Name="AddFriday" Content="{DynamicResource FridayShort}" VerticalAlignment="Center" />
                                <CheckBox x:Name="AddSaturday" Content="{DynamicResource SaturdayShort}" VerticalAlignment="Center" />
                                <CheckBox x:Name="AddSunday" Content="{DynamicResource SundayShort}" VerticalAlignment="Center" />
                            </UniformGrid>
                        </Grid>
                        <StackPanel Grid.Row="1">
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="270" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource TelegramConfirmation}" VerticalAlignment="Center" />
                                <ComboBox x:Name="ConfirmationPeerBox" Grid.Column="1" DisplayMemberPath="Name" />
                                <TextBlock Grid.Column="2" Text="{DynamicResource ConfirmationEmail}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                <TextBox x:Name="ConfirmationEmailBox" Grid.Column="3" ToolTip="可留空" />
                                <TextBlock Grid.Column="4" Text="{DynamicResource ConfirmationContent}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                <TextBox x:Name="ConfirmationTextBox" Grid.Column="5"
                                         Text="签到完成：{群聊}，时间 {时间}" ToolTip="支持 {群聊}、{时间}、{内容}" />
                            </Grid>
                        </StackPanel>
                        <TextBlock Grid.Row="2" Foreground="#64748B" VerticalAlignment="Center"
                                   Text="勾选任务后才能执行、编辑或删除；双击任务可启用/停用。应用保持运行并登录时按本机时区执行。" />
                        <ListView x:Name="ScheduleList" Grid.Row="3" SelectionMode="Extended"
                                  MouseDoubleClick="ScheduleList_MouseDoubleClick">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{DynamicResource Select}" Width="55">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{DynamicResource Status}" Width="70" DisplayMemberBinding="{Binding EnabledText}" />
                                    <GridViewColumn Header="{DynamicResource Chat}" Width="240" DisplayMemberBinding="{Binding ChatTitle}" />
                                    <GridViewColumn Header="{DynamicResource Period}" Width="170" DisplayMemberBinding="{Binding PeriodText}" />
                                    <GridViewColumn Header="{DynamicResource MessageContent}" Width="340" DisplayMemberBinding="{Binding Message}" />
                                    <GridViewColumn Header="{DynamicResource CompletionNotification}" Width="220" DisplayMemberBinding="{Binding Confirmation}" />
                                    <GridViewColumn Header="{DynamicResource LastSent}" Width="120" DisplayMemberBinding="{Binding LastSentText}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>
                <TabItem Header="{DynamicResource Mentions}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" />
                            <RowDefinition Height="44" />
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="300" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="MentionNotifyEnabledBox" Content="{DynamicResource EnableNotification}"
                                      VerticalAlignment="Center" />
                            <ComboBox x:Name="MentionTargetBox" Grid.Column="1" Margin="8,0"
                                      DisplayMemberPath="Name" ToolTip="选择机器人或私聊" />
                            <Button Grid.Column="2" Content="{DynamicResource SaveSettings}" Click="SaveMentionSettings_Click" />
                            <Button Grid.Column="3" Content="{DynamicResource TestNotification}" Click="TestMentionNotification_Click" />
                            <Button Grid.Column="4" Content="{DynamicResource OpenDataDirectory}" Click="OpenMentionDatabase_Click" />
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource Keyword}" VerticalAlignment="Center" />
                            <TextBox x:Name="MentionKeywordBox" Grid.Column="1" Margin="8,0"
                                     ToolTip="搜索群聊、发送人或消息内容" />
                            <Button Grid.Column="2" Content="{DynamicResource Search}" Click="RefreshMentions_Click" />
                            <Button Grid.Column="3" Content="{DynamicResource Reset}" Click="ResetMentionQuery_Click" />
                        </Grid>
                        <TextBlock Grid.Row="2" Foreground="#64748B" VerticalAlignment="Center"
                                   Text="只记录其他人 @ 当前账号的消息；记录和通知配置按 Telegram 账号隔离。双击查看完整内容。" />
                        <ListView x:Name="MentionList" Grid.Row="3"
                                  MouseDoubleClick="MentionList_MouseDoubleClick">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{DynamicResource OccurredAt}" Width="170" DisplayMemberBinding="{Binding OccurredAtText}" />
                                    <GridViewColumn Header="{DynamicResource Chat}" Width="220" DisplayMemberBinding="{Binding ChatName}" />
                                    <GridViewColumn Header="{DynamicResource Sender}" Width="150" DisplayMemberBinding="{Binding Sender}" />
                                    <GridViewColumn Header="{DynamicResource MessageContent}" Width="430" DisplayMemberBinding="{Binding Message}" />
                                    <GridViewColumn Header="{DynamicResource NotificationStatus}" Width="180" DisplayMemberBinding="{Binding NotificationStatus}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>
                <TabItem Header="{DynamicResource Exceptions}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" />
                            <RowDefinition Height="44" />
                            <RowDefinition Height="44" />
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="165" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="ExceptionNotifyEnabledBox" Content="{DynamicResource EnableAutoNotification}"
                                      VerticalAlignment="Center" />
                            <ComboBox x:Name="ExceptionMinimumLevelBox" Grid.Column="1" Margin="8,0">
                                <ComboBoxItem Content="{DynamicResource ErrorOrHigher}" Tag="Error" />
                                <ComboBoxItem Content="{DynamicResource CriticalOnly}" Tag="Critical" />
                            </ComboBox>
                            <TextBlock Grid.Column="2" Text="Telegram" VerticalAlignment="Center" />
                            <ComboBox x:Name="ExceptionPeerBox" Grid.Column="3" DisplayMemberPath="Name" />
                            <TextBlock Grid.Column="4" Text="{DynamicResource NotificationEmail}" VerticalAlignment="Center" Margin="10,0,4,0" />
                            <TextBox x:Name="ExceptionEmailBox" Grid.Column="5" ToolTip="留空表示不发送邮件" />
                        </Grid>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <Button Content="{DynamicResource SaveNotificationSettings}" Click="SaveExceptionSettings_Click" />
                            <Button Content="{DynamicResource TestNotification}" Click="TestExceptionNotification_Click" />
                            <Button Content="{DynamicResource RetryNotification}" Click="RetryExceptionNotifications_Click" />
                            <Button Content="{DynamicResource OpenDatabaseDirectory}" Click="OpenExceptionDatabase_Click" />
                        </StackPanel>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource StartDate}" VerticalAlignment="Center" />
                            <DatePicker x:Name="ExceptionFromDatePicker" Grid.Column="1" Margin="4,0,8,0" />
                            <TextBlock Grid.Column="2" Text="{DynamicResource EndDate}" VerticalAlignment="Center" />
                            <DatePicker x:Name="ExceptionToDatePicker" Grid.Column="3" Margin="4,0,8,0" />
                            <TextBlock Grid.Column="4" Text="{DynamicResource Level}" VerticalAlignment="Center" />
                            <ComboBox x:Name="ExceptionQueryLevelBox" Grid.Column="5" Margin="4,0,8,0">
                                <ComboBoxItem Content="{DynamicResource All}" Tag="All" />
                                <ComboBoxItem Content="Error" Tag="Error" />
                                <ComboBoxItem Content="Critical" Tag="Critical" />
                            </ComboBox>
                            <TextBlock Grid.Column="6" Text="{DynamicResource Keyword}" VerticalAlignment="Center" />
                            <TextBox x:Name="ExceptionKeywordBox" Grid.Column="7" Margin="4,0,8,0"
                                     ToolTip="搜索来源、异常消息和堆栈" />
                            <Button Grid.Column="8" Content="{DynamicResource Search}" Click="RefreshExceptions_Click" />
                            <Button Grid.Column="9" Content="{DynamicResource Reset}" Click="ResetExceptionQuery_Click" />
                        </Grid>
                        <TextBlock Grid.Row="3" Foreground="#64748B" VerticalAlignment="Center"
                                   Text="仅带 Exception/堆栈的 Error、Critical 日志写入 SQLite；双击记录查看详情，列表支持多选重发。" />
                        <ListView x:Name="ExceptionList" Grid.Row="4" SelectionMode="Extended"
                                  MouseDoubleClick="ExceptionList_MouseDoubleClick">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{DynamicResource Number}" Width="70" DisplayMemberBinding="{Binding Id}" />
                                    <GridViewColumn Header="{DynamicResource OccurredAt}" Width="170" DisplayMemberBinding="{Binding OccurredAtText}" />
                                    <GridViewColumn Header="{DynamicResource Level}" Width="80" DisplayMemberBinding="{Binding Level}" />
                                    <GridViewColumn Header="{DynamicResource Source}" Width="130" DisplayMemberBinding="{Binding Category}" />
                                    <GridViewColumn Header="{DynamicResource ExceptionMessage}" Width="360" DisplayMemberBinding="{Binding Message}" />
                                    <GridViewColumn Header="Telegram" Width="170" DisplayMemberBinding="{Binding TelegramStatus}" />
                                    <GridViewColumn Header="{DynamicResource Email}" Width="170" DisplayMemberBinding="{Binding EmailStatus}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>
                <TabItem Header="{DynamicResource Outbox}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" />
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{DynamicResource Refresh}" Click="RefreshOutbox_Click" />
                            <Button Content="{DynamicResource RetrySelected}" Click="RetryOutbox_Click" />
                            <Button Content="{DynamicResource OpenDatabaseDirectory}" Click="OpenOutboxDatabase_Click" />
                        </StackPanel>
                        <TextBlock Grid.Row="1" Foreground="#64748B" VerticalAlignment="Center"
                                   Text="{DynamicResource OutboxHint}" />
                        <ListView x:Name="OutboxList" Grid.Row="2" SelectionMode="Extended">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{DynamicResource Number}" Width="70" DisplayMemberBinding="{Binding Id}" />
                                    <GridViewColumn Header="{DynamicResource OccurredAt}" Width="170" DisplayMemberBinding="{Binding CreatedAtText}" />
                                    <GridViewColumn Header="{DynamicResource Status}" Width="100" DisplayMemberBinding="{Binding StatusText}" />
                                    <GridViewColumn Header="{DynamicResource Target}" Width="210" DisplayMemberBinding="{Binding TargetTitle}" />
                                    <GridViewColumn Header="{DynamicResource Purpose}" Width="110" DisplayMemberBinding="{Binding PurposeText}" />
                                    <GridViewColumn Header="{DynamicResource MessageContent}" Width="360" DisplayMemberBinding="{Binding MessagePreview}" />
                                    <GridViewColumn Header="{DynamicResource Attempts}" Width="80" DisplayMemberBinding="{Binding AttemptCount}" />
                                    <GridViewColumn Header="Telegram ID" Width="100" DisplayMemberBinding="{Binding TelegramMessageId}" />
                                    <GridViewColumn Header="{DynamicResource Error}" Width="280" DisplayMemberBinding="{Binding Error}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>
                <TabItem Header="{DynamicResource RuntimeLogs}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{DynamicResource OpenLogDirectory}" Click="OpenLogDirectory_Click" />
                            <Button Content="{DynamicResource ClearDisplay}" Click="ClearLogDisplay_Click" />
                            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#64748B"
                                       Text="日志按天保存，自动保留最近 30 天；不记录密码、验证码和消息正文。" />
                        </StackPanel>
                        <local:BufferedTerminal x:Name="LogConsole" Grid.Row="1"
                                                FontFamily="Cascadia Mono, Consolas" FontSize="13"
                                                Background="#090D12" Foreground="#F8FAFC"
                                                BorderBrush="#1E293B" BorderThickness="1"
                                                MaximumLines="2000" MaximumCharacters="1000000" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="8" Margin="0,8,0,0" Padding="4">
            <TextBox x:Name="StatusText" IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                     VerticalContentAlignment="Center" Foreground="#415064"
                     Background="Transparent" BorderThickness="0" Padding="4,2"
                     ToolTip="状态信息支持选择复制，内容较长时可上下滚动查看" />
        </Border>
    </Grid>
</Window>
