<Window x:Class="TelegramConsoleApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Telegram 控制台助手（WTelegramClient / WPF）"
        Width="1280" Height="820" MinWidth="1040" MinHeight="700"
        WindowStartupLocation="CenterScreen" Background="#F5F7FA"
        FontFamily="Microsoft YaHei UI" FontSize="13">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <GroupBox Header="连接配置" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="230" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>

                <TextBlock Text="API ID" VerticalAlignment="Center" Margin="4" />
                <TextBox x:Name="ApiIdBox" Grid.Column="1" />
                <TextBlock Grid.Column="2" Text="API Hash" VerticalAlignment="Center" Margin="8,4,4,4" />
                <PasswordBox x:Name="ApiHashBox" Grid.Column="3" />
                <TextBlock Grid.Column="4" Text="手机号" VerticalAlignment="Center" Margin="8,4,4,4" />
                <TextBox x:Name="PhoneBox" Grid.Column="5" />
                <Grid Grid.Column="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="86" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="LoginButton" Content="一键登录"
                            Click="LoginButton_Click" Background="{StaticResource AccentBrush}"
                            Foreground="White" FontWeight="SemiBold" />
                    <Button Grid.Column="1" Content="⚙ 设置" Click="SettingsButton_Click" />
                </Grid>

                <TextBlock x:Name="LoginPromptLabel" Grid.Row="1" Text="验证码"
                           VerticalAlignment="Center" Visibility="Collapsed" Margin="4" />
                <TextBox x:Name="LoginValueBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5"
                         Visibility="Collapsed" KeyDown="LoginValueBox_KeyDown" />
                <PasswordBox x:Name="LoginPasswordBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5"
                             Visibility="Collapsed" KeyDown="LoginPasswordBox_KeyDown" />
                <Button x:Name="ContinueLoginButton" Grid.Row="1" Grid.Column="6" Content="继续登录"
                        Visibility="Collapsed" Click="ContinueLoginButton_Click" />
            </Grid>
        </GroupBox>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="DialogColumn" Width="290" MinWidth="0" />
                <ColumnDefinition Width="34" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="70" />
                    </Grid.ColumnDefinitions>
                    <Button Content="刷新会话" Click="RefreshDialogs_Click" Margin="0,0,3,0" />
                    <Button Grid.Column="1" Content="独立控制台" Click="OpenConsole_Click" Margin="3,0,0,0" />
                    <Button Grid.Column="2" Content="空屏" Click="BlankConsole_Click" Margin="6,0,0,0"
                            ToolTip="取消当前会话并停止在聊天终端显示消息" />
                </Grid>
                <TextBox x:Name="DialogFilterBox" Grid.Row="1" TextChanged="DialogFilterBox_TextChanged"
                         ToolTip="输入名称筛选会话" Margin="0,0,0,6" />
                <ListBox x:Name="DialogsList" Grid.Row="2" SelectionChanged="DialogsList_SelectionChanged"
                         MouseDoubleClick="DialogsList_MouseDoubleClick"
                         DisplayMemberPath="Name" BorderBrush="#CBD5E1">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="在独立控制台中打开" Click="OpenConsole_Click" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>
            </Grid>

            <Grid Grid.Column="1">
                <GridSplitter Width="7" HorizontalAlignment="Left" Background="#E2E8F0" />
                <Button x:Name="ToggleDialogsButton" Content="❮" Width="26" Height="64"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Padding="0" Margin="0" ToolTip="收起会话列表"
                        Click="ToggleDialogsButton_Click" />
            </Grid>

            <TabControl Grid.Column="2" Margin="4,0,0,0">
                <TabItem Header="聊天终端">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="48" />
                        </Grid.RowDefinitions>
                        <RichTextBox x:Name="ChatConsole" IsReadOnly="True" FontFamily="Cascadia Mono, Consolas"
                                     FontSize="14" Background="#000000" Foreground="#FFFFFF"
                                     BorderThickness="1" VerticalScrollBarVisibility="Auto" />
                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="MessageBox" AcceptsReturn="True" KeyDown="MessageBox_KeyDown"
                                     ToolTip="Enter 发送，Shift+Enter 换行" Margin="0,0,8,0" />
                            <Button Grid.Column="1" Content="发送" Click="SendButton_Click"
                                    Background="{StaticResource AccentBrush}" Foreground="White" Margin="0" />
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="群消息监控">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="38" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <CheckBox x:Name="MonitorEnabledBox"
                                  Content="启用群消息监控（实时显示收到和发出的群消息）"
                                  VerticalAlignment="Center" Checked="MonitorEnabledBox_Changed"
                                  Unchecked="MonitorEnabledBox_Changed" />
                        <RichTextBox x:Name="MonitorConsole" Grid.Row="1" IsReadOnly="True"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="14" Background="#000000"
                                     Foreground="#FFFFFF" VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </TabItem>

                <TabItem Header="定时签到">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="32" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="38" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="群聊" VerticalAlignment="Center" />
                            <ComboBox x:Name="ScheduleChatBox" Grid.Column="1" DisplayMemberPath="Name" />
                            <TextBlock Grid.Column="2" Text="时间" VerticalAlignment="Center" Margin="8,0,0,0" />
                            <TextBox x:Name="ScheduleTimeBox" Grid.Column="3" Text="08:00" />
                            <TextBlock Grid.Column="4" Text="内容" VerticalAlignment="Center" Margin="8,0,0,0" />
                            <TextBox x:Name="ScheduleMessageBox" Grid.Column="5" Text="今日签到" />
                            <Button Grid.Column="6" Content="添加任务" Click="AddSchedule_Click" />
                            <Button x:Name="RunNowButton" Grid.Column="7" Content="立即执行" Click="RunNow_Click"
                                    Background="#2481CC" Foreground="White" />
                            <Button Grid.Column="8" Content="编辑选中" Click="EditSchedule_Click" />
                            <Button Grid.Column="9" Content="删除选中" Click="RemoveSchedule_Click" />
                            <TextBlock Grid.Row="1" Text="周期" VerticalAlignment="Center" />
                            <ComboBox x:Name="SchedulePeriodBox" Grid.Row="1" Grid.Column="1"
                                      SelectionChanged="SchedulePeriodBox_SelectionChanged">
                                <ComboBoxItem Content="每天" Tag="Daily" />
                                <ComboBoxItem Content="每周" Tag="Weekly" />
                            </ComboBox>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="星期" VerticalAlignment="Center" Margin="8,0,0,0" />
                            <UniformGrid x:Name="ScheduleWeekDaysPanel" Grid.Row="1" Grid.Column="3"
                                         Grid.ColumnSpan="7" Rows="1" IsEnabled="False" Margin="4,0">
                                <CheckBox x:Name="AddMonday" Content="一" VerticalAlignment="Center" />
                                <CheckBox x:Name="AddTuesday" Content="二" VerticalAlignment="Center" />
                                <CheckBox x:Name="AddWednesday" Content="三" VerticalAlignment="Center" />
                                <CheckBox x:Name="AddThursday" Content="四" VerticalAlignment="Center" />
                                <CheckBox x:Name="AddFriday" Content="五" VerticalAlignment="Center" />
                                <CheckBox x:Name="AddSaturday" Content="六" VerticalAlignment="Center" />
                                <CheckBox x:Name="AddSunday" Content="日" VerticalAlignment="Center" />
                            </UniformGrid>
                        </Grid>
                        <StackPanel Grid.Row="1">
                            <Grid Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Telegram 确认" VerticalAlignment="Center" />
                                <ComboBox x:Name="ConfirmationPeerBox" Grid.Column="1" DisplayMemberPath="Name" />
                                <TextBlock Grid.Column="2" Text="确认邮件" VerticalAlignment="Center" Margin="8,0,0,0" />
                                <TextBox x:Name="ConfirmationEmailBox" Grid.Column="3" ToolTip="可留空" />
                                <TextBlock Grid.Column="4" Text="确认内容" VerticalAlignment="Center" Margin="8,0,0,0" />
                                <TextBox x:Name="ConfirmationTextBox" Grid.Column="5"
                                         Text="签到完成：{群聊}，时间 {时间}" ToolTip="支持 {群聊}、{时间}、{内容}" />
                            </Grid>
                            <Expander Header="邮件 SMTP 配置（仅在需要邮件通知时填写）" Margin="0,4,0,0">
                                <Grid Margin="0,5,0,5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="75" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="服务器" VerticalAlignment="Center" />
                                    <TextBox x:Name="SmtpHostBox" Grid.Column="1" />
                                    <TextBlock Grid.Column="2" Text="端口" VerticalAlignment="Center" />
                                    <TextBox x:Name="SmtpPortBox" Grid.Column="3" Text="587" />
                                    <TextBlock Grid.Column="4" Text="账号" VerticalAlignment="Center" />
                                    <TextBox x:Name="SmtpUserBox" Grid.Column="5" />
                                    <TextBlock Grid.Column="6" Text="密码/授权码" VerticalAlignment="Center" />
                                    <PasswordBox x:Name="SmtpPasswordBox" Grid.Column="7" />
                                    <CheckBox x:Name="SmtpSslBox" Grid.Column="8" Content="SSL" IsChecked="True" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="1" Text="发件地址" VerticalAlignment="Center" />
                                    <TextBox x:Name="SmtpFromBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" />
                                    <Button Grid.Row="1" Grid.Column="5" Content="保存邮件配置" Click="SaveEmailSettings_Click" />
                                </Grid>
                            </Expander>
                        </StackPanel>
                        <TextBlock Grid.Row="2" Foreground="#64748B" VerticalAlignment="Center"
                                   Text="应用保持运行并登录时按本机时区执行；错过时间后当天补发一次。双击任务可启用/停用。" />
                        <ListView x:Name="ScheduleList" Grid.Row="3" SelectionMode="Extended"
                                  MouseDoubleClick="ScheduleList_MouseDoubleClick">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="状态" Width="70" DisplayMemberBinding="{Binding EnabledText}" />
                                    <GridViewColumn Header="群聊" Width="240" DisplayMemberBinding="{Binding ChatTitle}" />
                                    <GridViewColumn Header="周期" Width="170" DisplayMemberBinding="{Binding PeriodText}" />
                                    <GridViewColumn Header="发送内容" Width="340" DisplayMemberBinding="{Binding Message}" />
                                    <GridViewColumn Header="完成通知" Width="220" DisplayMemberBinding="{Binding Confirmation}" />
                                    <GridViewColumn Header="上次发送" Width="120" DisplayMemberBinding="{Binding LastSentText}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>
                <TabItem Header="异常中心">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" />
                            <RowDefinition Height="44" />
                            <RowDefinition Height="44" />
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="240" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="ExceptionNotifyEnabledBox" Content="启用自动通知"
                                      VerticalAlignment="Center" />
                            <ComboBox x:Name="ExceptionMinimumLevelBox" Grid.Column="1" Margin="8,0">
                                <ComboBoxItem Content="错误及以上" Tag="Error" />
                                <ComboBoxItem Content="仅严重异常" Tag="Critical" />
                            </ComboBox>
                            <TextBlock Grid.Column="2" Text="Telegram" VerticalAlignment="Center" />
                            <ComboBox x:Name="ExceptionPeerBox" Grid.Column="3" DisplayMemberPath="Name" />
                            <TextBlock Grid.Column="4" Text="通知邮箱" VerticalAlignment="Center" Margin="10,0,4,0" />
                            <TextBox x:Name="ExceptionEmailBox" Grid.Column="5" ToolTip="留空表示不发送邮件" />
                        </Grid>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <Button Content="保存通知配置" Click="SaveExceptionSettings_Click" />
                            <Button Content="测试通知" Click="TestExceptionNotification_Click" />
                            <Button Content="重发选中通知" Click="RetryExceptionNotifications_Click" />
                            <Button Content="打开数据库目录" Click="OpenExceptionDatabase_Click" />
                        </StackPanel>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="145" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="145" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="开始日期" VerticalAlignment="Center" />
                            <DatePicker x:Name="ExceptionFromDatePicker" Grid.Column="1" Margin="4,0,8,0" />
                            <TextBlock Grid.Column="2" Text="结束日期" VerticalAlignment="Center" />
                            <DatePicker x:Name="ExceptionToDatePicker" Grid.Column="3" Margin="4,0,8,0" />
                            <TextBlock Grid.Column="4" Text="级别" VerticalAlignment="Center" />
                            <ComboBox x:Name="ExceptionQueryLevelBox" Grid.Column="5" Margin="4,0,8,0">
                                <ComboBoxItem Content="全部" Tag="All" />
                                <ComboBoxItem Content="Error" Tag="Error" />
                                <ComboBoxItem Content="Critical" Tag="Critical" />
                            </ComboBox>
                            <TextBlock Grid.Column="6" Text="关键字" VerticalAlignment="Center" />
                            <TextBox x:Name="ExceptionKeywordBox" Grid.Column="7" Margin="4,0,8,0"
                                     ToolTip="搜索来源、异常消息和堆栈" />
                            <Button Grid.Column="8" Content="查询" Click="RefreshExceptions_Click" />
                            <Button Grid.Column="9" Content="重置" Click="ResetExceptionQuery_Click" />
                        </Grid>
                        <TextBlock Grid.Row="3" Foreground="#64748B" VerticalAlignment="Center"
                                   Text="仅带 Exception/堆栈的 Error、Critical 日志写入 SQLite；双击记录查看详情，列表支持多选重发。" />
                        <ListView x:Name="ExceptionList" Grid.Row="4" SelectionMode="Extended"
                                  MouseDoubleClick="ExceptionList_MouseDoubleClick">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="编号" Width="70" DisplayMemberBinding="{Binding Id}" />
                                    <GridViewColumn Header="发生时间" Width="170" DisplayMemberBinding="{Binding OccurredAtText}" />
                                    <GridViewColumn Header="级别" Width="80" DisplayMemberBinding="{Binding Level}" />
                                    <GridViewColumn Header="来源" Width="130" DisplayMemberBinding="{Binding Category}" />
                                    <GridViewColumn Header="异常消息" Width="360" DisplayMemberBinding="{Binding Message}" />
                                    <GridViewColumn Header="Telegram" Width="170" DisplayMemberBinding="{Binding TelegramStatus}" />
                                    <GridViewColumn Header="邮件" Width="170" DisplayMemberBinding="{Binding EmailStatus}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem>
                <TabItem Header="运行日志">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="打开日志目录" Click="OpenLogDirectory_Click" />
                            <Button Content="清空当前显示" Click="ClearLogDisplay_Click" />
                            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#64748B"
                                       Text="日志按天保存，自动保留最近 30 天；不记录密码、验证码和消息正文。" />
                        </StackPanel>
                        <RichTextBox x:Name="LogConsole" Grid.Row="1" IsReadOnly="True"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="13"
                                     Background="#000000" Foreground="#FFFFFF" BorderThickness="0"
                                     VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Margin="0,8,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#415064" />
        </Border>
    </Grid>
</Window>
