<Window x:Class="TelegramConsoleApp.AccountManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TelegramConsoleApp"
        Title="TelegramConsole 管理中心" Icon="Assets/AppIcon.ico"
        Width="1120" Height="720" MinWidth="880" MinHeight="560"
        WindowStartupLocation="CenterScreen" Background="{StaticResource PageBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="44" />
        </Grid.RowDefinitions>

        <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="10" Padding="16,11" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="TelegramConsole 管理中心" FontSize="18" FontWeight="Bold" Foreground="#0F172A" />
                    <TextBlock Text="统一管理账号、设备资源、异常与运行日志" Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="⚙ 设置" MinWidth="96" Click="Settings_Click" />
                <Button Grid.Column="2" Content="退出应用" MinWidth="96" Click="Exit_Click" />
            </Grid>
        </Border>

        <TabControl x:Name="CenterTabs" Grid.Row="1">
            <TabItem Header="账户管理">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="＋ 添加账户" Style="{StaticResource PrimaryButtonStyle}" Click="Add_Click" />
                            <Button Content="登录 / 打开工作区" Click="Open_Click" />
                            <Button Content="停止运行" Click="Stop_Click" />
                            <Button Content="平铺工作区" Click="Tile_Click" />
                        </StackPanel>
                        <Button Content="刷新" HorizontalAlignment="Right" Click="Refresh_Click" />
                    </Grid>
                    <DataGrid x:Name="AccountsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" CanUserAddRows="False" HeadersVisibility="Column"
                              SelectionUnit="FullRow" MouseDoubleClick="AccountsGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="账号备注" Binding="{Binding LocalName}" Width="170" />
                            <DataGridTextColumn Header="Telegram 账号" Binding="{Binding DisplayName}" Width="*" />
                            <DataGridTextColumn Header="手机号" Binding="{Binding MaskedPhone}" Width="150" />
                            <DataGridTextColumn Header="运行状态" Binding="{Binding Status}" Width="140" />
                            <DataGridCheckBoxColumn Header="自动启动" Binding="{Binding AutoStart}" Width="90" />
                            <DataGridTemplateColumn Header="启用 AI" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding AiEnabled}" Tag="{Binding UserId}"
                                                  HorizontalAlignment="Center" Click="AccountAiEnabled_Click" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="操作" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding ActionText}" Tag="{Binding UserId}" Padding="8,3" Margin="3"
                                                IsEnabled="{Binding CanOpen}" Click="RowOpen_Click" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"
                                   Text="账号工作区负责聊天与自动化；关闭工作区只隐藏，停止运行才会断开。" />
                        <Button Content="从列表移除" HorizontalAlignment="Right" Click="Remove_Click" />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="设备资源">
                <Grid Margin="12">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <UniformGrid Columns="4">
                        <Border Style="{StaticResource ResourceCardStyle}">
                            <StackPanel><TextBlock Text="内存" Foreground="#64748B" FontWeight="SemiBold"/><TextBlock x:Name="ResourceMemoryText" Text="--" FontSize="22" FontWeight="Bold"/><TextBlock x:Name="ResourceMemoryDetailText" Text="--" Foreground="#64748B" TextWrapping="Wrap"/></StackPanel>
                        </Border>
                        <Border Style="{StaticResource ResourceCardStyle}">
                            <StackPanel><TextBlock Text="应用数据" Foreground="#64748B" FontWeight="SemiBold"/><TextBlock x:Name="ResourceStorageText" Text="--" FontSize="22" FontWeight="Bold"/><TextBlock x:Name="ResourceStorageDetailText" Text="--" Foreground="#64748B" TextWrapping="Wrap"/></StackPanel>
                        </Border>
                        <Border Style="{StaticResource ResourceCardStyle}">
                            <StackPanel><TextBlock Text="磁盘 I/O" Foreground="#64748B" FontWeight="SemiBold"/><TextBlock x:Name="ResourceDiskText" Text="--" FontSize="16" FontWeight="Bold"/><TextBlock x:Name="ResourceDiskDetailText" Text="--" Foreground="#64748B" TextWrapping="Wrap"/></StackPanel>
                        </Border>
                        <Border Style="{StaticResource ResourceCardStyle}">
                            <StackPanel><TextBlock Text="Telegram 流量" Foreground="#64748B" FontWeight="SemiBold"/><TextBlock x:Name="ResourceNetworkText" Text="--" FontSize="16" FontWeight="Bold"/><TextBlock x:Name="ResourceNetworkDetailText" Text="--" Foreground="#64748B" TextWrapping="Wrap"/></StackPanel>
                        </Border>
                    </UniformGrid>
                    <TextBlock Grid.Row="1" Margin="4,12" Foreground="#64748B"
                               Text="资源每 2 秒统一采集一次；流量为本次程序启动后全部账号的 Telegram TCP 合计。" />
                    <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="公共资源只在管理中心采集" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="账号工作区不再重复启动资源定时器，减少目录扫描和界面刷新开销。" Foreground="#64748B" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="异常中心">
                <Grid Margin="12">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="刷新异常" Click="RefreshExceptions_Click" />
                        <Button Content="打开数据目录" Click="OpenDataDirectory_Click" />
                        <TextBlock x:Name="ExceptionSummaryText" VerticalAlignment="Center" Foreground="#64748B" Margin="12,0,0,0" />
                    </StackPanel>
                    <DataGrid x:Name="ExceptionsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="155" />
                            <DataGridTextColumn Header="账号" Binding="{Binding Account}" Width="150" />
                            <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="80" />
                            <DataGridTextColumn Header="来源" Binding="{Binding Category}" Width="140" />
                            <DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="*" />
                            <DataGridTextColumn Header="Telegram" Binding="{Binding TelegramStatus}" Width="105" />
                            <DataGridTextColumn Header="邮件" Binding="{Binding EmailStatus}" Width="105" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="运行日志">
                <Grid Margin="12">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="打开日志目录" Click="OpenLogDirectory_Click" />
                        <Button Content="清空当前显示" Click="ClearLogs_Click" />
                        <TextBlock Text="汇总当前进程内所有账号工作区日志，日志文件保留 30 天。" Foreground="#64748B" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </StackPanel>
                    <local:BufferedTerminal x:Name="GlobalLogConsole" Grid.Row="1" FontFamily="Cascadia Mono, Consolas" FontSize="13"
                                            Background="#090D12" Foreground="#F8FAFC" BorderBrush="#1E293B" BorderThickness="1"
                                            MaximumLines="3000" MaximumCharacters="1500000" />
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Margin="0,10,0,0" Padding="12,6">
            <TextBlock x:Name="CenterStatusText" Text="管理中心已就绪" VerticalAlignment="Center" Foreground="#475569" />
        </Border>
    </Grid>
</Window>
